# 说明：当前项目默认通过系统环境变量读取配置，本文件是给你对照填写用的模板，
# 不会被后端自动加载。如需生效，请在启动前写入系统环境变量，或使用根目录脚本启动。

APP_ENV=development
PORT=3000

# 区域测试阶段建议全部使用 memory，部署最简单
USER_STORE_DRIVER=memory
AUTH_RUNTIME_DRIVER=memory
RUNTIME_STATE_DRIVER=memory

# 如果后续切到 PostgreSQL，再填写下面这些
DB_HOST=127.0.0.1
DB_PORT=5432
DB_NAME=sunliao
DB_USER=sunliao
DB_PASSWORD=sunliao_dev

# 如果后续切到 Redis，再填写下面这些
REDIS_HOST=127.0.0.1
REDIS_PORT=6379
SESSION_TTL_SECONDS=604800
RUNTIME_STATE_PREFIX=sunliao:
