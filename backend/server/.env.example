# ── Runtime ──────────────────────────────────────────────────
NODE_ENV=development
PORT=3000

# ── JWT ──────────────────────────────────────────────────────
JWT_SECRET=change_me_in_production_use_32plus_chars
JWT_EXPIRES_IN=15m
JWT_REFRESH_EXPIRES_IN=30d
SESSION_TTL_SECONDS=2592000

# ── Storage drivers ──────────────────────────────────────────
# Options: memory | postgres
USER_STORE_DRIVER=postgres

# Options: memory | redis
AUTH_RUNTIME_DRIVER=redis
RUNTIME_STATE_DRIVER=redis

# ── PostgreSQL ───────────────────────────────────────────────
DB_HOST=127.0.0.1
DB_PORT=5432
DB_NAME=sunliao
DB_USER=sunliao
DB_PASSWORD=sunliao_dev

# ── Redis ────────────────────────────────────────────────────
REDIS_HOST=127.0.0.1
REDIS_PORT=6379
# REDIS_PASSWORD=   # uncomment if redis requires auth

RUNTIME_STATE_PREFIX=runtime:

# ── OTP ──────────────────────────────────────────────────────
# OTP_PROVIDER=mock   # mock (default) | aliyun
# ALIYUN_SMS_ACCESS_KEY=
# ALIYUN_SMS_SECRET=
# ALIYUN_SMS_SIGN=
# ALIYUN_SMS_TEMPLATE=

# ── CORS ─────────────────────────────────────────────────────
# Comma-separated allowed origins for WebSocket gateway
# CORS_ORIGINS=http://localhost:3000

# ── Media ────────────────────────────────────────────────────
# MEDIA_DRIVER=local
# MEDIA_BASE_PATH=./uploads
# S3_BUCKET=
# S3_REGION=
# S3_ACCESS_KEY=
# S3_SECRET_KEY=
